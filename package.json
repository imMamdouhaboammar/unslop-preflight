{
  "name": "unslop-preflight",
  "version": "1.11.0",
  "description": "Autopilot design quality gates and source-level UI slop detectors for AI-assisted frontend work before implementation handoff.",
  "type": "module",
  "exports": {
    ".": "./src/cli.js",
    "./rules": "./src/rules/index.js"
  },
  "bin": {
    "unslop-preflight": "bin/cli.js",
    "unslop": "bin/cli.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "build": "node --check bin/cli.js && node --check src/cli.js && node --check src/core/autopilotPlan.js && node --check src/core/sourceScanner.js && node --check src/core/report.js",
    "autopilot": "node bin/cli.js autopilot",
    "repair": "node bin/cli.js repair",
    "scan": "node bin/cli.js scan",
    "pack:dry-run": "npm pack --dry-run",
    "evals": "node scripts/run-evals.mjs",
    "validate:design": "node scripts/validate-design-md.mjs DESIGN.md",
    "score:design": "node scripts/score-design-md.mjs DESIGN.md PRODUCT.md",
    "gates": "node scripts/run-gates.mjs DESIGN.md PRODUCT.md src",
    "scan:ui": "node scripts/scan-ui-implementation.mjs src",
    "scan:a11y": "node scripts/scan-accessibility.mjs src",
    "scan:viewport": "node scripts/scan-viewport-fit.mjs http://localhost:3000",
    "preflight": "node bin/cli.js preflight",
    "cli": "node bin/cli.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skill",
    "skills-sh",
    "design-system",
    "design-md",
    "product-md",
    "ui-quality",
    "ai-coding",
    "vibe-coding",
    "anti-slop",
    "unslop",
    "accessibility",
    "wcag",
    "rtl",
    "design-tokens",
    "ux",
    "frontend-quality",
    "ai-agent",
    "code-agent",
    "design-gates",
    "web-design",
    "saas-design",
    "dashboard",
    "claude-skill",
    "cursor-skill",
    "codex-skill",
    "windsurf-skill",
    "cline-skill",
    "ai-ui-design",
    "design-md-generator",
    "design-md-repair",
    "frontend-guardrails",
    "rtl-ui",
    "arabic-ui",
    "wcag-22",
    "modal-governance",
    "overlay-governance",
    "viewport-governance",
    "floating-ui",
    "agents-md",
    "ai-agent-readiness",
    "taste-calibration",
    "typography-governance",
    "placeholder-gates",
    "root-cause-mode",
    "z-index-governance",
    "stacking-context",
    "agent-harness",
    "source-slop-detectors",
    "vibe-coder-tools"
  ],
  "author": "imMamdouhaboammar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imMamdouhaboammar/unslop-preflight.git"
  },
  "homepage": "https://github.com/imMamdouhaboammar/unslop-preflight#readme",
  "bugs": {
    "url": "https://github.com/imMamdouhaboammar/unslop-preflight/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "references/",
    "assets/",
    "evals/",
    "docs/",
    "AGENTS.md",
    "SKILL.md",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "skills.sh.json"
  ]
}
