{
  "name": "vibe-design-md-architect",
  "version": "1.9.0",
  "description": "A pre-agent design artifact quality gate for PRODUCT.md, DESIGN.md, and AGENT.md.",
  "type": "module",
  "main": "src/cli.js",
  "exports": {
    ".": "./src/cli.js",
    "./rules": "./src/rules/index.js"
  },
  "bin": {
    "vibe-design-md-architect": "./bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "examples",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "smoke": "node ./bin/cli.js --help && node ./bin/cli.js --version",
    "lint": "node --check bin/cli.js && find src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "ci": "npm run lint && npm test && npm run smoke",
    "prepublishOnly": "npm run ci"
  },
  "keywords": [
    "ai-coding",
    "vibe-coding",
    "cli",
    "design-docs",
    "product-spec",
    "quality-gates",
    "developer-experience"
  ],
  "author": "Mamdouh Aboammar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imMamdouhaboammar/vibe-design-md-architect.git"
  },
  "bugs": {
    "url": "https://github.com/imMamdouhaboammar/vibe-design-md-architect/issues"
  },
  "homepage": "https://github.com/imMamdouhaboammar/vibe-design-md-architect#readme"
}